{
  "name": "laundry-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "generate:icons": "node scripts/generate-icons.mjs",
    "test:supabase": "node scripts/test-supabase-sync.mjs",
    "setup:supabase": "node scripts/apply-supabase-migrations.mjs && npx vite-node scripts/seed-hydrate.ts",
    "seed:supabase": "npx vite-node scripts/seed-hydrate.ts",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "benchmark:inventory": "npx vite-node scripts/benchmark-inventory.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^22.20.0",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "postgres": "^3.4.9",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0"
  }
