{
  "name": "laundry-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "generate:icons": "node scripts/generate-icons.mjs",
    "test:supabase": "node scripts/test-supabase-sync.mjs",
    "setup:supabase": "node scripts/apply-supabase-migrations.mjs && npx vite-node scripts/seed-hydrate.ts",
    "generate:department-items-sql": "node scripts/generate-department-items-setup-sql.mjs",
    "generate:department-item-categories-sql": "node scripts/generate-department-item-categories-sql.mjs",
    "apply:department-items": "node scripts/apply-department-items-setup.mjs",
    "apply:department-item-categories": "node scripts/apply-department-item-categories.mjs",
    "apply:department-inventory-assignments": "node scripts/apply-department-inventory-assignments.mjs",
    "apply:inventory-permissions": "node scripts/apply-inventory-permissions.mjs",
    "apply:push-notifications": "node scripts/apply-shift-push-notifications.mjs",
    "deploy:edge-functions": "node scripts/deploy-edge-functions.mjs",
    "seed:supabase": "npx vite-node scripts/seed-hydrate.ts",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:push-notifications": "node scripts/verify-push-notifications-db.mjs",
    "verify:plan-compat": "node scripts/verify-plan-backward-compat.mjs",
    "verify:department-items": "node scripts/verify-department-items.mjs",
    "verify:department-items-crud": "node scripts/verify-department-items-crud.mjs",
    "verify:department-item-categories-crud": "node scripts/verify-department-item-categories-crud.mjs",
    "verify:inventory-permissions": "node scripts/verify-inventory-permissions.mjs",
    "verify:department-inventory-assignments": "node scripts/verify-department-inventory-assignments.mjs",
    "verify:department-catalog": "npm run verify:supabase && npm run verify:department-items && npm run verify:department-items-crud && npm run verify:department-item-categories-crud && npm run verify:plan-compat",
    "verify:inventory-catalog": "npm run build && npm run verify:supabase && npm run verify:inventory-permissions && npm run verify:plan-compat",
    "benchmark:inventory": "npx vite-node scripts/benchmark-inventory.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dompurify": "^3.4.11",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-onesignal": "^3.5.6",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.20.0",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "postgres": "^3.4.9",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0"
  }
}
